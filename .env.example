# ─── Server ────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# MongoDB — replace with your Atlas connection string
MONGO_URI=mongodb://localhost:27017/cleanledger

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_in_production
JWT_EXPIRES_IN=7d

# CORS — Frontend origin
CLIENT_ORIGIN=http://localhost:5173

# JARVIS / Mistral — set on the machine running the Python AI service (server/ai_service)
# Node proxies /api/v1/voice/* to this URL
AI_SERVICE_URL=http://localhost:5001
# Windows example: absolute path to Python 3.10+ (used by npm run dev → ai-service)
# AI_SERVICE_PYTHON=C:\\Users\\You\\AppData\\Local\\Programs\\Python\\Python311\\python.exe
# MISTRAL_API_KEY=your_mistral_key
# Free / dev tier: use mistral-small-latest (default in ai_service). Paid: mistral-large-latest, etc.
# MISTRAL_CHAT_MODEL=mistral-small-latest
# Optional: MISTRAL_USE_SDK=1  (set 0 to force REST-only)
